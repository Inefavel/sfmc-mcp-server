{
  "name": "sfmc-mcp-server",
  "version": "0.2.0",
  "description": "MCP Server para Salesforce Marketing Cloud — valide queries do Automation Studio antes de rodar, explore Data Extensions e consulte registros direto do Claude.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sfmc-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx test/validateSql.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sfmc",
    "salesforce-marketing-cloud",
    "marketing-cloud",
    "automation-studio",
    "data-extensions",
    "claude",
    "ampscript",
    "sql-validation"
  ],
  "author": "Luiz Claudio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inefavel/sfmc-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Inefavel/sfmc-mcp-server/issues"
  },
  "homepage": "https://github.com/Inefavel/sfmc-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
