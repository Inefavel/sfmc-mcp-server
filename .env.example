# Credenciais do Installed Package do SFMC (Server-to-Server / client_credentials)
# Setup > Installed Packages > New > Add Component > API Integration (Server-to-Server)

# Subdomínio da sua instância (a parte antes de .auth.marketingcloudapis.com)
SFMC_SUBDOMAIN=mcXXXXXXXXXXXXXXXXXXXXXXXX

SFMC_CLIENT_ID=seu_client_id
SFMC_CLIENT_SECRET=seu_client_secret

# Opcional: MID da Business Unit alvo (account_id). Se omitido, usa a BU padrão do package.
SFMC_ACCOUNT_ID=

# Modo de operação: "read" (padrão, apenas leitura) ou "write" (habilita upsert/criação)
SFMC_MODE=read
